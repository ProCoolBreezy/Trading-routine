# Copy to .env and fill in your Alpaca keys.
# Get paper keys at: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here

# LIVE_TRADING must be explicitly set to "true" to trade real money.
# Anything else (unset, "false", "0") uses the paper account.
LIVE_TRADING=false
